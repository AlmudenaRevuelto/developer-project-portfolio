{% extends "layout/base.twig" %}

{% block title %}
Home | Developer Portfolio
{% endblock %}

{% block content %}

<h2>My Projects</h2>

<div class="projects-grid">

    {% for project in projects %}
        {% include "components/project-card.twig" with { project: project } %}
    {% else %}
        <p>No projects available.</p>
    {% endfor %}

</div>

{% endblock %}